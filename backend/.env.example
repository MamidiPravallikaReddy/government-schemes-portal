# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1
SECRET_KEY=your-super-secret-key-min-32-characters-here

# Database - Local MongoDB (no Docker)
ML_SERVICE_URL=http://localhost:5001
MONGODB_URI=mongodb://localhost:27017/gov_schemes
# No Docker means using localhost instead of container names

# Redis - Local Redis
REDIS_HOST=localhost  # Not 'redis' as in Docker
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# OTP Configuration
# ==========================================
# Choose one of: development, twilio, aws-sns, vonage, msg91, fastotp
OTP_PROVIDER=development

# For Twilio (Global SMS Provider)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# For AWS SNS (AWS Infrastructure)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_REGION=ap-south-1

# For Vonage/Nexmo
VONAGE_API_KEY=your_api_key_here
VONAGE_API_SECRET=your_api_secret_here
VONAGE_BRAND_NAME=YourAppName

# For MSG91 (India - Recommended)
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=GOVSCH

# For FastOTP (India)
FASTOTP_API_KEY=your_fastotp_api_key_here

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
MAX_OTP_ATTEMPTS=5

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS - Local frontend
# If React starts on port 3001 because 3000 is busy, allow it too.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Logging
LOG_LEVEL=info
LOG_FILE=app.log

# Chatbot
CHATBOT_CONFIDENCE_THRESHOLD=0.6
MAX_HISTORY_MESSAGES=50

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key